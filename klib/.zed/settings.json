{
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "cargo": {
          "target": "aarch64-mars-none",
          "extraArgs": [
            "-p",
            "kernel",
            "-Z",
            "build-std=core,compiler_builtins,alloc",
          ],
          "extraEnv": {
            "RUSTFLAGS": "-Zunstable-options",
          },
        },
        "check": {
          "workspace": false,
        },
      },
    },
  },
}
